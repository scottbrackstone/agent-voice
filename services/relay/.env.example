PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# OpenClaw is connector #1, not the product identity.
# Uses the OpenClaw Gateway OpenAI-compatible HTTP endpoint:
# POST /v1/chat/completions
# Enable gateway.http.endpoints.chatCompletions.enabled in OpenClaw before live use.
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=
OPENCLAW_TOKEN=
OPENCLAW_MODEL=openclaw
OPENCLAW_USER=agentvoice-mobile
OPENCLAW_SESSION_KEY=
OPENCLAW_AGENT_ID=
OPENCLAW_TIMEOUT_MS=10000

# Hermes connector. Assumes an OpenAI-compatible chat endpoint:
# POST /v1/chat/completions
HERMES_ENABLED=false
HERMES_BASE_URL=
HERMES_TOKEN=
HERMES_MODEL=hermes
HERMES_USER=agentvoice-mobile
HERMES_TIMEOUT_MS=30000

# Optional turn-based Voxtral transcription for Android Driving Mode.
# Keep this key on the relay. Do not put it in Android.
MISTRAL_API_KEY=
VOXTRAL_TRANSCRIBE_MODEL=voxtral-mini-latest
VOXTRAL_TRANSCRIBE_LANGUAGE=en
VOXTRAL_TRANSCRIBE_TIMEOUT_MS=90000
